{
  "version": 2,
  "regions": ["bom1"],
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "*.html",
          "*.css",
          "*.js",
          "Logos/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/ping",
      "dest": "server.js",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "src": "/(.*\\.(png|jpg|jpeg|svg|ico|webp|woff2?))",
      "dest": "server.js",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*\\.(css|js))",
      "dest": "server.js",
      "headers": {
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
